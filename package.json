{
  "name": "tome",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "build:cf": "NITRO_PRESET=cloudflare-module vite build",
    "preview": "vite preview",
    "cf:preview": "pnpm build:cf && wrangler dev",
    "cf:deploy": "pnpm build:cf && wrangler deploy",
    "cf:tail": "wrangler tail tome",
    "cf:secret": "wrangler secret put --name tome",
    "test": "vitest run",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed-editor-packs": "tsx scripts/seed-editor-packs.ts",
    "db:rebucket": "tsx scripts/rebucket.ts",
    "db:delete-booker-pack": "tsx scripts/delete-booker-pack.ts",
    "db:reset-my-collection": "tsx scripts/reset-my-collection.ts",
    "favicons": "tsx scripts/favicons.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "better-auth": "^1.6.5",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.545.0",
    "nitro": "npm:nitro-nightly@latest",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^28.1.0",
    "msw": "^2.13.4",
    "png-to-ico": "^3.0.1",
    "postgres": "^3.4.9",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vitest": "^3.0.5",
    "wrangler": "^4.84.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
