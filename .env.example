# ──────────────────────────────────────────────────────────────────────────────
# Neon Postgres
# ──────────────────────────────────────────────────────────────────────────────
# Get this from Neon → your project → Dashboard → Connect → Connection string.
# Prefer the POOLED connection string (host contains `-pooler`). At runtime
# we use `@neondatabase/serverless` over WebSockets (works on Cloudflare
# Workers and supports interactive transactions).
DATABASE_URL=postgresql://<user>:<password>@<project>-pooler.<region>.aws.neon.tech/<db>?sslmode=require

# ──────────────────────────────────────────────────────────────────────────────
# Better Auth
# ──────────────────────────────────────────────────────────────────────────────
# Generate once with: openssl rand -base64 32
# Rotate by changing this value — existing sessions will be invalidated.
BETTER_AUTH_SECRET=

# The canonical origin Better Auth uses to build callback URLs and validate
# CSRF. In dev this is usually http://localhost:3000; in production it must
# match the deployed origin exactly (no trailing slash).
BETTER_AUTH_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────────
# Google OAuth (server-only)
# ──────────────────────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client.
# Authorized redirect URIs must include:
#   http://localhost:3000/api/auth/callback/google    (dev)
#   https://<your-prod-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# Hardcover GraphQL API (server-only)
# ──────────────────────────────────────────────────────────────────────────────
HARDCOVER_API_TOKEN=
