# ──────────────────────────────────────────────────────────────────────────────
# Supabase Postgres
# ──────────────────────────────────────────────────────────────────────────────
# Both URLs come from Supabase → Project Settings → Database → Connection string.
# The password is your DB password (NOT the anon/publishable key).

# Runtime queries from server functions. Use the TRANSACTION POOLER (port 6543).
# postgres-js is configured with `prepare: false` in src/db/client.ts, which
# is what lets it work with pgbouncer's transaction mode — you do NOT need
# the `?pgbouncer=true` query param (Cloudflare's URL parser is strict and
# unnecessary params can mask real issues).
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Drizzle migrations. Use the SESSION POOLER (port 5432) — DDL needs a real
# session with prepared-statement support.
DATABASE_MIGRATION_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ──────────────────────────────────────────────────────────────────────────────
# Supabase client (browser-safe)
# ──────────────────────────────────────────────────────────────────────────────
# Supabase dashboard → Project settings → API keys.
# Use the new "publishable" key (starts with `sb_publishable_`). The legacy
# "anon public" key still works but is being phased out.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ──────────────────────────────────────────────────────────────────────────────
# Hardcover GraphQL API (server-only)
# ──────────────────────────────────────────────────────────────────────────────
HARDCOVER_API_TOKEN=
