# Secrets consumed by `wrangler dev` (local Workers runtime preview via
# `pnpm cf:preview`). Copy to `.dev.vars` (gitignored) and fill in real
# values. Production uses `wrangler secret put <NAME>` instead of this file.
#
# In practice `.env.local` is usually enough for local dev — `wrangler
# dev` will fall back to Worker secrets for any value not set here, and
# `pnpm dev` (vite) reads `.env.local` directly. Use this file if you
# specifically want `wrangler dev` to exercise a different set of values
# than your vite-dev workflow.

# Neon pooled connection string (host contains `-pooler`).
DATABASE_URL=

# Better Auth server secret. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Canonical origin Better Auth uses for CSRF + OAuth callback URL construction.
# For `wrangler dev` this is typically http://localhost:8787.
BETTER_AUTH_URL=http://localhost:8787

# Google OAuth client (redirect URI for the above origin must be registered
# in Google Cloud Console).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Hardcover GraphQL API token (server-only). See .env.example.
HARDCOVER_API_TOKEN=

# Comma-separated list of admin emails. See .env.example.
ADMIN_EMAILS=
